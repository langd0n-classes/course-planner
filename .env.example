# Copy to .env and fill in real values
# Never commit .env

# Database (used by both app and db service)
POSTGRES_USER=courseplanner
POSTGRES_PASSWORD=courseplanner
POSTGRES_DB=courseplanner
DATABASE_URL=postgresql://courseplanner:courseplanner@db:5432/courseplanner?schema=public

# Auth
AUTH_SECRET=                  # generate: openssl rand -base64 32
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_URL=http://localhost:3000
ALLOWED_EMAIL=
COURSE_PLANNER_PREVIEW_AUTH=false
COURSE_PLANNER_PREVIEW_EMAIL=
